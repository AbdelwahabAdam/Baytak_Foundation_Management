# Local Docker Compose configuration only. Do not reuse these defaults in production.
POSTGRES_DB=charity
POSTGRES_USER=charity
POSTGRES_PASSWORD=replace-with-a-local-password
JWT_SECRET_KEY=replace-with-a-long-random-local-secret
BOOTSTRAP_ADMIN_EMAIL=admin@charity.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
SCHEDULER_ENABLED=true
FRONTEND_APP_URL=http://localhost:8080
PASSWORD_RESET_MINUTES=30

# Application branding. Frontend VITE_* values are embedded when the frontend image is built.
APP_NAME=Baytak Foundation API
VITE_APP_NAME=Baytak Foundation
VITE_APP_SHORT_NAME=Baytak
VITE_APP_TAGLINE=Community charity management
VITE_APP_DESCRIPTION=Transparent, people-first charity operations.
VITE_APP_CONTACT_EMAIL=info@baytakfoundation.org
VITE_APP_LOGO_PATH=/baytak-logo.png
VITE_DEFAULT_LOCALE=ar
VITE_NAVIGATION_TITLE=Workspace

# Sidebar tab labels
VITE_TAB_OVERVIEW=Overview
VITE_TAB_DONORS=Donors
VITE_TAB_DONATIONS=Donations
VITE_TAB_DONATION_TYPES=Donation types
VITE_TAB_WAREHOUSE=Warehouse
VITE_TAB_CASES=Cases
VITE_TAB_CUSTODY=Custody
VITE_TAB_APPROVALS=Approvals
VITE_TAB_REPORTS=Reports
VITE_TAB_SCHEDULED_REPORTS=Scheduled reports
VITE_TAB_USERS=Users
VITE_TAB_SETTINGS=Settings

# Theme colours
VITE_COLOR_PRIMARY=#1765a7
VITE_COLOR_PRIMARY_DARK=#104e85
VITE_COLOR_ACCENT=#2a78ba
VITE_COLOR_SIDEBAR=#123b65
VITE_COLOR_BACKGROUND=#f5f8fc
VITE_COLOR_SURFACE=#ffffff
VITE_COLOR_TEXT=#162b3d
VITE_COLOR_MUTED_TEXT=#607285
VITE_COLOR_SUCCESS=#167044
VITE_COLOR_WARNING=#a86b09
VITE_COLOR_DANGER=#ae3f34

# SMTP delivery for scheduled reports. Leave blank to keep email disabled.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=reports@example.com
SMTP_PASSWORD=replace-with-an-smtp-password
SMTP_FROM=reports@example.com
SMTP_STARTTLS=true
